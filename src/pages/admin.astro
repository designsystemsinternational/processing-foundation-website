---
const reactRefreshPreamble = import.meta.env.DEV
  ? `
      import RefreshRuntime from '/@react-refresh'
      RefreshRuntime.injectIntoGlobalHook(window)
      window.$RefreshReg$ = () => {}
      window.$RefreshSig$ = () => (type) => type
      window.__vite_plugin_react_preamble_installed__ = true
    `
  : "";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <link href="/config.yml" type="text/yaml" rel="cms-config-url" />
    <title>Content Manager</title>
    <script type="module" is:inline set:html={reactRefreshPreamble}></script>
  </head>
  <body>
    <script>
      import CMS from "decap-cms-app";
      import { createElement as h, useEffect, useRef, useState } from "react";
      import { slugify } from "@/lib/utils";

      const DEBOUNCE_MS = 300;

      interface PreviewProps {
        // eslint-disable-next-line @typescript-eslint/no-explicit-any
        entry: { getIn(path: string[]): any };
      }

      function PagePreview({ entry }: PreviewProps) {
        const [html, setHtml] = useState("");
        const data = entry.getIn(["data"])?.toJS?.() ?? {};
        const payload = JSON.stringify(data);
        const frame = useRef<HTMLIFrameElement>(null);

        useEffect(() => {
          const controller = new AbortController();
          const timer = setTimeout(() => {
            fetch("/preview", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: payload,
              signal: controller.signal,
            })
              .then((res) => res.text())
              .then(setHtml)
              .catch((err) => {
                if (err.name !== "AbortError") setHtml(`<pre>${String(err)}</pre>`);
              });
          }, DEBOUNCE_MS);
          return () => {
            clearTimeout(timer);
            controller.abort();
          };
        }, [payload]);

        return h("iframe", {
          ref: frame,
          srcDoc: html,
          title: "Page preview",
          style: {
            position: "fixed",
            inset: 0,
            width: "100%",
            height: "100%",
            border: "none",
          },
        });
      }

      CMS.registerPreviewTemplate("pages", PagePreview);

      // Collections whose "slug" field defaults to a slugified version of
      // another field on save, unless the editor already typed a custom
      // value into it.
      const SLUG_SOURCE_FIELD: Record<string, string> = {
        "blog-posts": "title",
        "blog-categories": "name",
      };

      CMS.registerEventListener({
        name: "preSave",
        handler: ({ entry }) => {
          const data = entry.get("data");
          const sourceField = SLUG_SOURCE_FIELD[entry.get("collection")];
          if (!sourceField || data.get("slug")) {
            return data;
          }
          return data.set("slug", slugify(data.get(sourceField) ?? ""));
        },
      });

      CMS.init();
    </script>
  </body>
</html>
